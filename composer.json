{
    "name": "manufacturing-erp/system",
    "type": "project",
    "description": "Manufacturing ERP System with ICICI Bank Theme",
    "keywords": ["erp", "manufacturing", "codeigniter"],
    "homepage": "https://codeigniter.com",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "codeigniter4/framework": "^4.4.8",
        "kint-php/kint": "^4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^9.1"
    },
    "autoload": {
        "psr-4": {
            "Config\\": "app/Config/",
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "app/Database/Migrations/",
            "tests/_support/Database/Migrations/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "post-update-cmd": [
            "@composer dump-autoload"
        ]
    },
    "support": {
        "source": "https://github.com/codeigniter4/CodeIgniter4",
        "issues": "https://github.com/codeigniter4/CodeIgniter4/issues",
        "forum": "https://forum.codeigniter.com/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
